# ─── Countermeasure Engine ─────────────────────────────────────────────────────
class CountermeasureEngine:
    """
    Routes countermeasure button clicks to the correct ESW1 SSH actions.

    DHCP Starvation buttons:
      'Block Attacker'    → isolate_attacker_port  (shutdown flood source port)
      'Isolate Device'    → rate_limit_dhcp_port   (rate-limit before full block)
      'Enable Protection' → enable_dhcp_snooping   (enable snooping all VLANs)

    Rogue DHCP buttons:
      'Block Rogue Server'   → block_rogue_dhcp_port  (shutdown port + snooping)
      'Enable DHCP Snooping' → enable_dhcp_snooping   (protect remaining VLANs)
      'Clear Bindings'       → clear_poisoned_bindings (recover poisoned clients)
    """

    def execute_countermeasure(self, alert_data: dict, measure_type: str = 'all') -> dict:
        src_ip      = alert_data.get('src_ip',        'unknown')
        subnet      = alert_data.get('target_subnet', 'unknown')
        attack_type = alert_data.get('attack_type',   'dhcp_starvation')
        timestamp   = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

        results = []

        # ── DHCP Starvation ────────────────────────────────────────────────────
        if attack_type == 'dhcp_starvation':

            if measure_type in ('all', 'Block Attacker'):
                r = esw1.isolate_attacker_port(subnet)
                results.append(self._fmt('Isolate Attacker Port', src_ip, r))

            if measure_type in ('all', 'Isolate Device'):
                r = esw1.rate_limit_dhcp_port(subnet)
                results.append(self._fmt('DHCP Rate Limiting', src_ip, r))

            if measure_type in ('all', 'Enable Protection'):
                r = esw1.enable_dhcp_snooping()
                results.append(self._fmt('DHCP Snooping', subnet, r))

        # ── Rogue DHCP Server ──────────────────────────────────────────────────
        elif attack_type == 'rogue_dhcp':

            if measure_type in ('all', 'Block Rogue Server'):
                # Step 1: shutdown rogue port + enable snooping
                r = esw1.block_rogue_dhcp_port(subnet)
                results.append(self._fmt('Block Rogue DHCP Port', src_ip, r))

            if measure_type in ('all', 'Enable DHCP Snooping'):
                # Step 2: ensure snooping covers all remaining VLANs
                r = esw1.enable_dhcp_snooping()
                results.append(self._fmt('DHCP Snooping All VLANs', subnet, r))

            if measure_type in ('all', 'Clear Bindings'):
                # Step 3: flush poisoned bindings so clients recover
                r = esw1.clear_poisoned_bindings()
                results.append(self._fmt('Clear Poisoned Bindings', src_ip, r))

        log_entry = {
            'timestamp':     timestamp,
            'alert_id':      alert_data.get('sid', 'unknown'),
            'attack_type':   attack_type,
            'src_ip':        src_ip,
            'subnet':        subnet,
            'measures':      results,
            'success_count': sum(1 for r in results if r['status'] == 'success'),
        }

        with lock:
            countermeasure_log.appendleft(log_entry)
            attack_stats['countermeasures_triggered'] += 1

        return log_entry

    @staticmethod
    def _fmt(type_name: str, target: str, result: dict) -> dict:
        return {
            'type':   type_name,
            'target': target,
            'status': result.get('status', 'error'),
            'detail': result.get('output', '')[:200],
            'action': result.get('action', type_name),
        }


