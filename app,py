# ─── Alert Classification ──────────────────────────────────────────────────────
def _classify_alert(line: str, msg: str):
    """
    Classifies an alert line as 'rogue_dhcp', 'dhcp_starvation', or None.
    Checks SID first (most reliable), then falls back to keyword matching.

    SID 1000001 → dhcp_starvation
    SID 1000002 → rogue_dhcp  (OFFER from non-ESW1)
    SID 1000003 → rogue_dhcp  (ACK   from non-ESW1)
    """
    # SID-based classification (primary)
    for sid in CONFIG['SID_ROGUE_DHCP']:
        if f':{sid}:' in line or f'[1:{sid}' in line:
            return 'rogue_dhcp'

    sid_starv = str(CONFIG['SID_DHCP_STARVATION'])
    if f':{sid_starv}:' in line or f'[1:{sid_starv}' in line:
        return 'dhcp_starvation'

    # Keyword fallback
    for kw in CONFIG['KEYWORDS_ROGUE_DHCP']:
        if kw.lower() in line.lower() or kw.lower() in msg.lower():
            return 'rogue_dhcp'
    for kw in CONFIG['KEYWORDS_STARVATION']:
        if kw.lower() in line.lower() or kw.lower() in msg.lower():
            return 'dhcp_starvation'

    return None


def parse_fast_alert_line(line: str):
    """
    Parses a single line from Snort's alert_fast.txt.
    Returns a structured alert dict or None if the line is not a DHCP attack.
    """
    try:
        # Quick pre-filter — only process lines containing DHCP-related content
        dhcp_keywords = (
            CONFIG['KEYWORDS_STARVATION'] +
            CONFIG['KEYWORDS_ROGUE_DHCP'] +
            [str(CONFIG['SID_DHCP_STARVATION'])] +
            [str(s) for s in CONFIG['SID_ROGUE_DHCP']]
        )
        if not any(kw.lower() in line.lower() for kw in dhcp_keywords):
            return None

        timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

        # Extract message from [**] ... [**] section
        msg = "DHCP Attack Detected"
        if '[**]' in line:
            parts = line.split('[**]')
            if len(parts) >= 2:
                msg_part = parts[1].strip()
                msg = msg_part.split('[')[0].strip() if '[' in msg_part else msg_part

        attack_type = _classify_alert(line, msg)
        if attack_type is None:
            return None

        # Resolve SID for this alert type
        if attack_type == 'rogue_dhcp':
            # Determine which rogue SID fired
            sid = CONFIG['SID_ROGUE_DHCP'][0]
            for s in CONFIG['SID_ROGUE_DHCP']:
                if str(s) in line:
                    sid = s
                    break
        else:
            sid = CONFIG['SID_DHCP_STARVATION']

        src_ip = dst_ip = 'unknown'
        src_port = dst_port = '0'
        protocol = 'UDP'

        # Parse src/dst from "A.B.C.D:port -> E.F.G.H:port"
        if '->' in line:
            arrow_parts = line.split('->')
            if len(arrow_parts) == 2:
                left  = arrow_parts[0].strip().split()
                right = arrow_parts[1].strip().split()

                src_full = left[-1]  if left  else 'unknown'
                dst_full = right[0]  if right else 'unknown'

                src_ip   = src_full.split(':')[0] if ':' in src_full else src_full
                src_port = src_full.split(':')[1] if ':' in src_full else ('67' if attack_type == 'rogue_dhcp' else '68')
                dst_ip   = dst_full.split(':')[0] if ':' in dst_full else dst_full
                dst_port = dst_full.split(':')[1] if ':' in dst_full else ('68' if attack_type == 'rogue_dhcp' else '67')

                for part in left:
                    if part.startswith('{') and part.endswith('}'):
                        protocol = part[1:-1]

        # Determine which campus subnet was targeted
        subnet = determine_subnet(dst_ip if attack_type == 'dhcp_starvation' else src_ip)

        display_msg = (
            "Rogue DHCP Server Detected — Unauthorized DHCP Response" if attack_type == 'rogue_dhcp'
            else "DHCP Starvation Attack — Pool Exhaustion Attempt"
        )
        if msg and msg != "DHCP Attack Detected":
            display_msg = msg

        return {
            'timestamp':     timestamp,
            'sid':           sid,
            'attack_type':   attack_type,
            'msg':           display_msg,
            'src_ip':        src_ip,
            'dst_ip':        dst_ip,
            'src_port':      src_port,
            'dst_port':      dst_port,
            'protocol':      protocol,
            'target_subnet': subnet,
            'src_mac':       lookup_mac(src_ip),
            'priority':      1 if attack_type == 'rogue_dhcp' else 2,
            'raw':           line.strip(),
        }

    except Exception as e:
        print(f"[parse_fast_alert_line] error: {e}")
        return None


# ─── Network Helpers ───────────────────────────────────────────────────────────
def determine_subnet(ip: str) -> str:
    """Returns the HOME_NET subnet string that contains the given IP, or 'unknown'."""
    try:
        ip_obj = ipaddress.ip_address(ip)
        for net_str in CONFIG['HOME_NETS']:
            if ip_obj in ipaddress.ip_network(net_str):
                return net_str
    except Exception:
        pass
    return 'unknown'


def lookup_mac(ip: str) -> str:
    """Looks up the MAC address for an IP using the ARP neighbour table."""
    try:
        result = subprocess.run(
            f"ip neigh show {ip}",
            shell=True, capture_output=True, text=True, timeout=2)
        if result.returncode == 0:
            parts = result.stdout.strip().split()
            for i, part in enumerate(parts):
                if part == 'lladdr' and i + 1 < len(parts):
                    return parts[i + 1]
    except Exception:
        pass
    return 'unknown'


# ─── Stats ─────────────────────────────────────────────────────────────────────
def update_attack_stats(alert: dict):
    subnet      = alert.get('target_subnet', 'unknown')
    src_ip      = alert.get('src_ip',        'unknown')
    attack_type = alert.get('attack_type',   'dhcp_starvation')

    with lock:
        attack_stats['total_alerts'] += 1

        if attack_type == 'rogue_dhcp':
            attack_stats['total_rogue_dhcp'] += 1
        else:
            attack_stats['total_starvation'] += 1

        attack_stats['attacks_by_subnet'][subnet] += 1
        attack_stats['attacks_by_src_ip'][src_ip] += 1

        current_min = datetime.now().strftime("%H:%M")
        for item in attack_stats['attack_timeline']:
            if item['time'] == current_min:
                item['count'] += 1
                break
        else:
            attack_stats['attack_timeline'].append({'time': current_min, 'count': 1})


def get_current_stats() -> dict:
    with lock:
        return {
            'total_alerts':              attack_stats['total_alerts'],
            'total_starvation':          attack_stats['total_starvation'],
            'total_rogue_dhcp':          attack_stats['total_rogue_dhcp'],
            'active_attacks':            len(active_countermeasures),
            'blocked_hosts':             len(attack_stats['blocked_hosts']),
            'countermeasures_triggered': attack_stats['countermeasures_triggered'],
            'attacks_by_subnet':         dict(attack_stats['attacks_by_subnet']),
            'attacks_by_src_ip':         dict(attack_stats['attacks_by_src_ip']),
            'timeline':                  list(attack_stats['attack_timeline']),
            'recent_alerts':             list(alert_history)[:10],
        }


# ─── Background Monitor ────────────────────────────────────────────────────────
def background_alert_monitor():
    """
    Tails alert_fast.txt in real-time, parses new lines, and pushes
    parsed alerts to connected dashboard clients via WebSocket.
    """
    print("[*] Starting background alert monitor…")
    fast_path     = os.path.join(CONFIG['SNORT_LOG_DIR'], CONFIG['ALERT_FAST_FILE'])
    last_position = 0
    last_size     = 0

    while True:
        try:
            if os.path.exists(fast_path):
                current_size = os.path.getsize(fast_path)
                if current_size > last_size:
                    with open(fast_path, 'r') as f:
                        f.seek(last_position)
                        new_lines     = f.readlines()
                        last_position = f.tell()
                        last_size     = current_size

                    for line in new_lines:
                        alert = parse_fast_alert_line(line)
                        if alert:
                            with lock:
                                alert_history.appendleft(alert)

                            update_attack_stats(alert)

                            socketio.emit('new_alert', {
                                'alert': alert,
                                'stats': get_current_stats(),
                            }, namespace='/')

                            if alert['src_ip'] not in active_countermeasures:
                                active_countermeasures[alert['src_ip']] = True

            time.sleep(2)

        except Exception as e:
            print(f"[monitor] error: {e}")
            time.sleep(5)


