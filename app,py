@app.route('/api/reset-dhcp', methods=['POST'])
def reset_dhcp():
    """
    Dashboard 'Reset DHCP Server' button.
    SSHes into ESW1 and clears all DHCP bindings then restarts the service.
    Safe to use after both starvation and rogue DHCP attacks.
    """
    print("[*] Reset DHCP Server requested via dashboard")
    result = esw1.reset_dhcp_server()

    log_entry = {
        'timestamp': datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        'action':    'DHCP Server Reset',
        'status':    result['status'],
        'detail':    result.get('output', '')[:300],
    }

    with lock:
        countermeasure_log.appendleft(log_entry)

    socketio.emit('dhcp_reset_result', {
        'status':  result['status'],
        'message': 'DHCP Server reset successfully — IP pool cleared' if result['status'] == 'success'
                   else f"Reset failed: {result.get('output', 'unknown error')}",
        'output':  result.get('output', ''),
    }, namespace='/')

    return jsonify({
        'status':  result['status'],
        'message': result.get('action', 'DHCP Reset'),
        'output':  result.get('output', ''),
    })


@app.route('/api/countermeasures/execute', methods=['POST'])
def execute_countermeasure():
    """
    Handles all countermeasure button clicks from alert cards.
    Dispatches to the correct ESW1 SSH action based on attack type + measure type.
    """
    data         = request.get_json()
    alert        = data.get('alert', {})
    measure_type = data.get('type', 'all')

    print(f"[*] Countermeasure: '{measure_type}' for {alert.get('src_ip')} [{alert.get('attack_type')}]")

    result = counter_engine.execute_countermeasure(alert, measure_type)

    socketio.emit('countermeasure_executed', {
        'result': result,
        'stats':  get_current_stats(),
    }, namespace='/')

    return jsonify(result)


