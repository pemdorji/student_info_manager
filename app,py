@socketio.on('request_countermeasure')
def handle_countermeasure_request(data):
    alert        = data.get('alert', {})
    measure_type = data.get('type', 'all')
    result       = counter_engine.execute_countermeasure(alert, measure_type)
    emit('countermeasure_result', {
        'success': result['success_count'] > 0,
        'result':  result,
        'stats':   get_current_stats(),
    }, broadcast=True)


@socketio.on('reset_server')
def handle_reset_server(data):
    print("[*] Reset server via WebSocket")
    result = esw1.reset_dhcp_server()
    emit('dhcp_reset_result', {
        'status':  result['status'],
        'message': 'DHCP Server reset successfully' if result['status'] == 'success'
                   else f"Reset failed: {result.get('output', '')}",
    }, broadcast=True)


