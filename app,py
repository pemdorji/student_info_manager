# ─── SSH Helper ────────────────────────────────────────────────────────────────
class ESW1SSH:
    """
    Manages SSH sessions to ESW1 for executing IOS countermeasure commands.
    Monitoring-1 reaches ESW1 via the management VLAN 99 SVI (192.168.1.1).
    """

    def __init__(self):
        self.host     = CONFIG['ESW1_HOST']
        self.port     = CONFIG['ESW1_PORT']
        self.username = CONFIG['ESW1_USER']
        self.password = CONFIG['ESW1_PASSWORD']
        self.timeout  = CONFIG['ESW1_TIMEOUT']

    def _connect(self):
        client = paramiko.SSHClient()
        client.set_missing_host_key_policy(paramiko.AutoAddPolicy())
        client.connect(
            self.host,
            port=self.port,
            username=self.username,
            password=self.password,
            timeout=self.timeout,
            look_for_keys=False,
            allow_agent=False,
        )
        return client

    def run_commands(self, commands: list) -> dict:
        output_lines = []
        try:
            client  = self._connect()
            channel = client.invoke_shell()
            time.sleep(1)

            channel.send('terminal length 0\n')
            time.sleep(0.5)
            channel.recv(4096)

            for cmd in commands:
                channel.send(cmd + '\n')
                time.sleep(0.8)
                if channel.recv_ready():
                    chunk = channel.recv(4096).decode('utf-8', errors='ignore')
                    output_lines.append(chunk)

            time.sleep(0.5)
            while channel.recv_ready():
                output_lines.append(channel.recv(4096).decode('utf-8', errors='ignore'))

            channel.close()
            client.close()

            return {
                'status':   'success',
                'output':   '\n'.join(output_lines),
                'commands': commands,
            }

        except paramiko.AuthenticationException:
            return {'status': 'error', 'output': 'SSH authentication failed — check ESW1 credentials', 'commands': commands}
        except paramiko.SSHException as e:
            return {'status': 'error', 'output': f'SSH error: {str(e)}', 'commands': commands}
        except Exception as e:
            return {'status': 'error', 'output': f'Connection failed: {str(e)}', 'commands': commands}

    # ── Countermeasure methods ─────────────────────────────────────────────────

    def reset_dhcp_server(self) -> dict:
        """
        Clears all DHCP bindings and restarts the DHCP service on ESW1.
        Use after starvation attack exhausts the pool OR after rogue server
        has poisoned bindings.
        """
        commands = [
            'clear ip dhcp binding *',
            'configure terminal',
            'no service dhcp',
            'service dhcp',
            'end',
            'show ip dhcp binding',
        ]
        result = self.run_commands(commands)
        result['action'] = 'DHCP Server Reset — bindings cleared, service restarted'
        return result

    def isolate_attacker_port(self, subnet: str) -> dict:
        """
        Shuts down the ESW1 downlink port for the given subnet.
        Used for DHCP starvation — cuts off the flooding source.
        """
        port = CONFIG['SUBNET_PORT_MAP'].get(subnet, CONFIG['ATTACKER_PORT'])
        commands = [
            'configure terminal',
            f'interface {port}',
            'shutdown',
            'end',
            f'show interface {port} status',
        ]
        result = self.run_commands(commands)
        result['action'] = f'Port isolation — {port} shutdown (starvation attacker)'
        result['port']   = port
        return result

    def enable_dhcp_snooping(self, vlan_ids: str = '10,20,30') -> dict:
        """
        Enables DHCP Snooping on ESW1 for all campus VLANs.
        Marks the router/uplink port as trusted; all other ports become
        untrusted — blocks any rogue DHCP server responses network-wide.
        """
        commands = [
            'configure terminal',
            'ip dhcp snooping',
            f'ip dhcp snooping vlan {vlan_ids}',
            'no ip dhcp snooping information option',
            'interface f1/0',            # uplink to router — adjust if different
            'ip dhcp snooping trust',
            'exit',
            'end',
            'show ip dhcp snooping',
        ]
        result = self.run_commands(commands)
        result['action'] = f'DHCP Snooping enabled on VLANs {vlan_ids} — all downlinks set untrusted'
        return result

    def rate_limit_dhcp_port(self, subnet: str, rate: int = 10) -> dict:
        """
        Applies DHCP snooping rate limiting on the attacker's port.
        Slows starvation floods without fully isolating the port.
        """
        port = CONFIG['SUBNET_PORT_MAP'].get(subnet, CONFIG['ATTACKER_PORT'])
        commands = [
            'configure terminal',
            f'interface {port}',
            f'ip dhcp snooping limit rate {rate}',
            'exit',
            'end',
            f'show ip dhcp snooping interface {port}',
        ]
        result = self.run_commands(commands)
        result['action'] = f'DHCP rate limit {rate} pps applied on {port}'
        result['port']   = port
        return result

    def block_rogue_dhcp_port(self, subnet: str) -> dict:
        """
        ROGUE DHCP countermeasure — Step 1:
        Shuts down the port the rogue server is on AND enables DHCP Snooping
        to prevent any other rogue servers from responding on remaining ports.
        """
        port = CONFIG['SUBNET_PORT_MAP'].get(subnet, CONFIG['ATTACKER_PORT'])
        commands = [
            'configure terminal',
            f'interface {port}',
            'shutdown',
            'exit',
            'ip dhcp snooping',
            'ip dhcp snooping vlan 10,20,30',
            'no ip dhcp snooping information option',
            'interface f1/0',
            'ip dhcp snooping trust',
            'exit',
            'end',
            'show ip dhcp snooping',
        ]
        result = self.run_commands(commands)
        result['action'] = f'Rogue DHCP blocked — port {port} shutdown + snooping enabled on all VLANs'
        result['port']   = port
        return result

    def clear_poisoned_bindings(self) -> dict:
        """
        ROGUE DHCP countermeasure — Step 3:
        After blocking the rogue server, clear all DHCP bindings so clients
        that received a rogue IP will re-request from the legitimate ESW1 server.
        This is the most important recovery step for rogue DHCP attacks.
        """
        commands = [
            'clear ip dhcp binding *',
            'configure terminal',
            'no service dhcp',
            'service dhcp',
            'end',
            'show ip dhcp binding',
            'show ip dhcp pool',
        ]
        result = self.run_commands(commands)
        result['action'] = 'Poisoned DHCP bindings cleared — clients will re-request from ESW1'
        return result

    def restore_port(self, subnet: str) -> dict:
        """Re-enables a previously shutdown port after the threat is resolved."""
        port = CONFIG['SUBNET_PORT_MAP'].get(subnet, CONFIG['ATTACKER_PORT'])
        commands = [
            'configure terminal',
            f'interface {port}',
            'no shutdown',
            'end',
            f'show interface {port} status',
        ]
        result = self.run_commands(commands)
        result['action'] = f'Port {port} restored (no shutdown)'
        result['port']   = port
        return result


